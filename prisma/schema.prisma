// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id           String   @id @default(uuid())
  title        String
  imageUrl     String
  content      String
  category     String
  categoryId   String?
  categoryRel  Category? @relation(fields: [categoryId], references: [id])
  isActive     Boolean  @default(true)
  overlayOpacity Int      @default(0)
  creatorId    String?
  creator      Admin?   @relation(fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contentHash  String?
  moderatorReviews ModeratorCardReview[]
  deviceImpressions    DeviceCardImpression[]

  @@index([contentHash])

  @@index([title])
  @@index([categoryId])
  @@index([creatorId])
  @@index([isActive])
}

/// Per-moderator review record: each Admin must review a card independently.
model ModeratorCardReview {
  id           String   @id @default(uuid())
  moderatorId  String
  moderator    Admin    @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
  cardId       String
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reviewedAt   DateTime @default(now())

  @@unique([moderatorId, cardId])
  @@index([moderatorId])
  @@index([cardId])
}

/// Per-device feed fairness: which cards the user app has already surfaced (fair rotation order).
model DeviceCardImpression {
  id          String   @id @default(uuid())
  deviceId    String
  cardId      String
  lastShownAt DateTime @default(now())
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deviceId, cardId])
  @@index([deviceId, lastShownAt])
}

/// Learned from dwell time: quick-skip vs longer reads, used to order fair feed by category.
model DeviceCategoryAffinity {
  id        String   @id @default(uuid())
  deviceId  String
  category  String
  /// Clamped typically to [-1, 1]. Higher = user tends to engage with this category.
  score     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([deviceId, category])
  @@index([deviceId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  cards       Card[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  cards     Card[]
  moderatorCardReviews ModeratorCardReview[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id        String   @id @default(uuid())
  type      String   // 'INFO', 'WARNING', 'CRITICAL'
  message   String
  source    String   // 'SYSTEM', 'DATABASE', 'API'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
