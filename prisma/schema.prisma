// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id           String   @id @default(uuid())
  title        String
  imageUrl     String
  content      String
  category     String
  categoryId   String?
  categoryRel  Category? @relation(fields: [categoryId], references: [id])
  isActive     Boolean  @default(true)
  overlayOpacity Int      @default(0)
  creatorId    String?
  creator      Admin?   @relation(fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contentHash  String?
  
  @@index([contentHash])

  @@index([title])
  @@index([categoryId])
  @@index([creatorId])
  @@index([isActive])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  cards       Card[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id        String   @id @default(uuid())
  type      String   // 'INFO', 'WARNING', 'CRITICAL'
  message   String
  source    String   // 'SYSTEM', 'DATABASE', 'API'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
